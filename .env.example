# Copy this file to `.env` and fill in real values.
# `.env` is gitignored and MUST NOT be committed.
# In prod/Docker/K8s these are provided as real environment variables.

# --- Slack ---
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...
# Only needed if using the Events API / request signature verification
SLACK_SIGNING_SECRET=

# --- App ---
# Comma-separated Slack channel IDs allowed to use the bot
APP_ALLOWED_CHANNELS=C...

# --- Database (override only if not using local defaults) ---
# R2DBC_URL=r2dbc:mysql://localhost:3306/blacklist_hub
# FLYWAY_URL=jdbc:mysql://localhost:3306/blacklist_hub
# DB_USERNAME=root
# DB_PASSWORD=root

# --- Server ---
# SERVER_PORT=8080
